{
  "name": "outloud",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev:android": "expo run:android",
    "dev:ios": "expo run:ios",
    "doctor": "npx expo-doctor",
    "export:android": "expo export --platform android --clear",
    "build:android:dev": "npx eas-cli build --platform android --profile development",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:android:production": "npx eas-cli build --platform android --profile production",
    "build:android:dev:win": "set \"PATH=C:\\Program Files\\Git\\cmd;C:\\Program Files\\Git\\bin;%PATH%\" && npx eas-cli build --platform android --profile development",
    "build:android:preview:win": "set \"PATH=C:\\Program Files\\Git\\cmd;C:\\Program Files\\Git\\bin;%PATH%\" && npx eas-cli build --platform android --profile preview",
    "build:android:production:win": "set \"PATH=C:\\Program Files\\Git\\cmd;C:\\Program Files\\Git\\bin;%PATH%\" && npx eas-cli build --platform android --profile production",
    "build:ios:production": "npx eas-cli build --platform ios --profile production",
    "submit:android": "npx eas-cli submit --platform android --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production",
    "test": "jest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "expo": "~54.0.35",
    "expo-av": "~16.0.7",
    "expo-camera": "~17.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-image-picker": "~17.0.11",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~54.0.7",
    "jest": "^29.7.0"
  },
  "overrides": {
    "@react-native/virtualized-lists": "0.81.5",
    "react-native": "0.81.5"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    }
  }
}
