{
  "expo": {
    "name": "OutLoud",
    "slug": "outloud",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "outloud",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "bundleIdentifier": "com.outloud.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "OutLoud uses your camera so you can share a daily candid photo.",
        "NSPhotoLibraryUsageDescription": "OutLoud uses your photo library so you can choose a profile picture.",
        "NSMicrophoneUsageDescription": "OutLoud uses your microphone so you can send voice notes to friends."
      }
    },
    "android": {
      "package": "com.outloud.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111111"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-dev-client",
      "expo-camera",
      "expo-image-picker",
      "expo-av",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "7475108e-126f-4aea-9205-ffba17386c60"
      }
    },
    "owner": "nkrute"
  }
}
